# Database Configuration
DATABASE_URL=postgresql://chatbot:password@localhost:5432/chatbot_db

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI API (Optional - app works without it)
OPENAI_API_KEY=your-openai-api-key-here

# Stripe Payment Processing
# Get your API keys from: https://dashboard.stripe.com/apikeys
# SECURITY: Use test keys (sk_test_...) in development, live keys (sk_live_...) in production only
STRIPE_API_KEY=sk_test_your_stripe_api_key_here
# Get webhook secret from: https://dashboard.stripe.com/webhooks
# CRITICAL: Required for webhook signature verification to prevent spoofing attacks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Redis
REDIS_URL=redis://localhost:6379

# File Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
CHROMA_DB_PATH=chroma_db

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Environment
ENVIRONMENT=development
DEBUG=true

# Frontend API URL
REACT_APP_API_URL=http://localhost:8000
